# Provider keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
# ── Firecrawl Self-Host Configuration ──────────────────────────────
# API key can remain empty when using local self-host with USE_DB_AUTHENTICATION=false
# Run: scripts/start_firecrawl_selfhost.sh  OR  docker compose up -d firecrawl-api
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=http://localhost:3002
# Strategy: self_hosted_first | cloud_only | self_hosted_only
FIRECRAWL_STRATEGY=self_hosted_first
FIRECRAWL_CLOUD_URL=https://api.firecrawl.dev
SARVAM_API_KEY=
HUGGINGFACE_API_TOKEN=

# Provider endpoints
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# If Chainlit runs on host machine, prefer localhost. Use http://ollama:11434 only when app runs inside Docker network.
OLLAMA_BASE_URL=http://localhost:11434

# LiteLLM router endpoint for CrewAI/LangChain
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-litellm-master-key
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_MODEL=premium-thinker

# Optional defaults used by orchestration scripts
RESEARCH_MODEL_GROQ=llama-3.3-70b-versatile
ANALYSIS_MODEL_OPENROUTER=llama-3.3-70b-versatile
VISUAL_MODEL_OPENROUTER=llama-3.3-70b-versatile
TRANSLATION_MODEL_SARVAM=sarvam-translate
OLLAMA_FALLBACK_MODEL=deepseek-r1:8b

# Semantic router and ensemble controls
ROUTER_DEFAULT_MODE=semantic
ENABLE_ENSEMBLE=true
ENSEMBLE_THRESHOLD=18

# Free model presets by provider
GROQ_MODEL_STRONG=openai/gpt-oss-120b
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_LONG_CONTEXT=llama-4-scout-17b

OPENROUTER_MODEL_STRONG_FREE=nvidia/nemotron-3-super-120b
OPENROUTER_MODEL_CODING_FREE=mistralai/devstral-2512
OPENROUTER_MODEL_FAST_FREE=stepfun/step-3.5-flash
OPENROUTER_MODEL_MULTIMODAL_FREE=google/gemma-3-27b-it
OPENROUTER_MODEL_AUTO_FREE=openrouter/free

SARVAM_MODEL_FLAGSHIP=sarvam-105b
SARVAM_MODEL_REALTIME=sarvam-30b

# Skill / artifact controls
ARTIFACTS_DIR=data/artifacts
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Agentic local RAG controls
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8000
RAG_CHROMA_LOCAL_PATH=data/chroma
RAG_COLLECTION_NAME=ray_docs
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_TOP_K=3

# Agentic orchestrator controls
AGENTIC_ENABLE_CREWAI=true
AGENTIC_DEFAULT_CHART=bar
AGENTIC_SYSTEM_PROMPT=You are RAY, an autonomous assistant for local-first research workflows. Prefer local Chroma RAG evidence first, then web scraping for missing context. Never fabricate facts, distinguish facts from assumptions, and clearly state when data is unavailable.

# Behavioral memory controls
BEHAVIOR_MEMORY_ENABLED=true
BEHAVIOR_MEMORY_COLLECTION=ray_behavior
BEHAVIOR_MEMORY_TOP_K=4

# Hardware profile
HARDWARE_VRAM_BUDGET_GB=4
HARDWARE_QUANTIZATION_PROFILE=GGUF + KV Cache Quantization

# Chainlit interface settings
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8001
