# ── Direct Providers (Sarvam, Groq) ──────────────────
SARVAM_API_KEY=
GROQ_API_KEY=

# ── Agent Runtime Selection ───────────────────────────────────────
RAY_AGENT_BACKEND=langgraph
CODEX_CLI_PATH=codex
CODEX_MODEL=openai/gpt-oss-20b
CODEX_PROVIDER_ID=groq
CODEX_BASE_URL=https://api.groq.com/openai/v1
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never

# ── Role-Based Model IDs ─────────────────────────────────────────
# Primary Reasoning (gpt-oss-120b or similar)

# Multilingual / Regional (Sarvam-105B)
MULTILINGUAL_SPECIALIST_MODEL=sarvam/sarvam-105b

# Multimodal Input (Vision/Audio/PDF - e.g., claude-3-5-sonnet)

# Image Generation (e.g., flux-1-dev or dall-e-3)

# Fast Background Tasks (Llama-3-8b on Groq)
FAST_ROUTING_MODEL=groq/llama3-8b-8192

# ── Ollama (local inference + embeddings) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Qdrant (vector store) ────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Collections used by the agent
QDRANT_BEHAVIOR_COLLECTION=behavior_index
QDRANT_DOCS_COLLECTION=documents

# ── Web Search ───────────────────────────────────────────────────
SERPAPI_API_KEY=

# ── Context Pipeline ─────────────────────────────────────────────
SUMMARIZE_EVERY_N_TURNS=6
SUMMARIZE_TOKEN_THRESHOLD=4000
RECENT_MESSAGES_WINDOW=6
TOKEN_BUDGET_WARN=8000
TOKEN_BUDGET_LIMIT=12000

# ── Chainlit ─────────────────────────────────────────────────────
CHAINLIT_AUTH_SECRET=change-me-in-production

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Deep Research (Firecrawl) ────────────────────────────────────
FIRECRAWL_API_KEY=
